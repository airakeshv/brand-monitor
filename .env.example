# Copy this file to .env and fill in your values

# --- Database ---
# On Railway: set to the mounted volume path so data survives redeploys
DATABASE_PATH=/data/brand-monitor.db

# --- Encryption ---
ENCRYPTION_KEY=change-me-to-a-random-secret

# --- Search ---
SERPER_API_KEY=

# --- Email delivery (Resend) ---
RESEND_API_KEY=
RESEND_FROM=BrandMonitor <onboarding@resend.dev>

# --- WhatsApp delivery (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# --- Reddit API (snoowrap) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
